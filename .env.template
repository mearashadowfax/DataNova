# Turso / libSQL database (required for feedback in production)
# Legacy ASTRO_DB_* names are still supported as fallbacks.

TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ASTRO_DB_REMOTE_URL=
# ASTRO_DB_APP_TOKEN=

# Set to 1 / true on production deploys to disable Keystatic admin routes
# SKIP_KEYSTATIC=1

# Keystatic storage: "local" (default) or "github"
# KEYSTATIC_STORAGE_MODE=local
# KEYSTATIC_GITHUB_REPO_OWNER=
# KEYSTATIC_GITHUB_REPO_NAME=

# Optional form delivery (Formspree or any JSON webhook).
# When unset, /api/contact and /api/newsletter run in demo mode (validate + log).
# FORMSPREE_CONTACT_ENDPOINT=https://formspree.io/f/your-id
# FORMSPREE_NEWSLETTER_ENDPOINT=https://formspree.io/f/your-id
# FORM_WEBHOOK_CONTACT=
# FORM_WEBHOOK_NEWSLETTER=
