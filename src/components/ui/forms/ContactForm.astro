---
const formStrings = {
  name: 'Name',
  email: 'Email',
  message: 'Message',
  submit: 'Submit',
  submitting: 'Sending…',
  success: 'Thanks! Your message has been sent.',
  error: 'Something went wrong. Please try again.',
};

/**
 * Submits to /api/contact.
 * Optional delivery: set FORMSPREE_CONTACT_ENDPOINT or FORM_WEBHOOK_CONTACT in .env
 */
---

<form
  id="contact-form"
  class="p-4"
  aria-labelledby="contact-form-title"
  data-form="contact"
  novalidate
>
  <fieldset class="space-y-4">
    <legend id="contact-form-title" class="sr-only">{formStrings.submit}</legend
    >

    {/* Honeypot – hidden from users */}
    <div class="hidden" aria-hidden="true">
      <label for="contact-website">Website</label>
      <input
        type="text"
        id="contact-website"
        name="website"
        tabindex="-1"
        autocomplete="off"
      />
    </div>

    <div class="relative">
      <input
        type="text"
        id="contact-name"
        name="name"
        class="peer block w-full rounded-lg border border-transparent p-4 text-sm not-placeholder-shown:pt-6 not-placeholder-shown:pb-2 placeholder:text-transparent autofill:pt-6 autofill:pb-2 focus:border-teal-700/80 focus:pt-6 focus:pb-2 focus:ring-2 focus:ring-teal-700/80 focus:outline-hidden focus-visible:ring-2 focus-visible:ring-teal-700/80"
        placeholder={formStrings.name}
        required
        aria-required="true"
        aria-labelledby="contact-name-label"
        autocomplete="name"
      />
      <label
        id="contact-name-label"
        for="contact-name"
        class="pointer-events-none absolute start-0 top-0 h-full truncate border border-transparent p-4 text-slate-600 transition duration-100 ease-in-out peer-not-placeholder-shown:-translate-y-1.5 peer-not-placeholder-shown:text-xs peer-not-placeholder-shown:text-slate-600 peer-focus:-translate-y-1.5 peer-focus:text-xs peer-focus:text-slate-600"
      >
        {formStrings.name}
      </label>
    </div>

    <div class="relative">
      <input
        type="email"
        id="contact-email"
        name="email"
        class="peer block w-full rounded-lg border border-transparent p-4 text-sm not-placeholder-shown:pt-6 not-placeholder-shown:pb-2 placeholder:text-transparent autofill:pt-6 autofill:pb-2 focus:border-teal-700/80 focus:pt-6 focus:pb-2 focus:ring-2 focus:ring-teal-700/80 focus:outline-hidden focus-visible:ring-2 focus-visible:ring-teal-700/80"
        placeholder={formStrings.email}
        required
        aria-required="true"
        aria-labelledby="contact-email-label"
        aria-describedby="contact-form-status"
        autocomplete="email"
      />
      <label
        id="contact-email-label"
        for="contact-email"
        class="pointer-events-none absolute start-0 top-0 h-full w-full truncate border border-transparent p-4 text-slate-600 transition duration-100 ease-in-out peer-not-placeholder-shown:-translate-y-1.5 peer-not-placeholder-shown:text-xs peer-not-placeholder-shown:text-slate-600 peer-focus:-translate-y-1.5 peer-focus:text-xs peer-focus:text-slate-600"
      >
        {formStrings.email}
      </label>
    </div>

    <div class="relative">
      <textarea
        id="contact-message"
        name="message"
        class="peer block w-full rounded-lg border border-transparent p-4 text-sm not-placeholder-shown:pt-6 not-placeholder-shown:pb-2 placeholder:text-transparent autofill:pt-6 autofill:pb-2 focus:border-teal-700/80 focus:pt-6 focus:pb-2 focus:ring-2 focus:ring-teal-700/80 focus:outline-hidden focus-visible:ring-2 focus-visible:ring-teal-700/80"
        placeholder={formStrings.message}
        required
        aria-required="true"
        aria-labelledby="contact-message-label"></textarea>
      <label
        id="contact-message-label"
        for="contact-message"
        class="pointer-events-none absolute start-0 top-0 h-full truncate border border-transparent p-4 text-slate-600 transition duration-100 ease-in-out peer-not-placeholder-shown:-translate-y-1.5 peer-not-placeholder-shown:text-xs peer-not-placeholder-shown:text-slate-600 peer-focus:-translate-y-1.5 peer-focus:text-xs peer-focus:text-slate-600"
      >
        {formStrings.message}
      </label>
    </div>
  </fieldset>

  <p
    id="contact-form-status"
    class="mt-4 hidden text-sm"
    role="status"
    aria-live="polite"
    data-form-status
  >
  </p>

  <div class="mt-8">
    <button
      type="submit"
      data-form-submit
      class="inline-flex items-center rounded-lg bg-teal-100 px-6 py-2 font-medium text-nowrap text-slate-700 transition-colors duration-300 hover:bg-teal-700/80 hover:text-white focus:bg-teal-700/80 focus:outline-hidden focus-visible:ring-2 focus-visible:ring-teal-700/80 focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-60"
      aria-label={formStrings.submit}
    >
      {formStrings.submit}
    </button>
  </div>
</form>

<script>
  import { bindJsonForm } from '@/utils/form-client';

  document.addEventListener('astro:page-load', () => {
    bindJsonForm({
      formId: 'contact-form',
      endpoint: '/api/contact',
      submittingLabel: 'Sending…',
      defaultSubmitLabel: 'Submit',
    });
  });
</script>
