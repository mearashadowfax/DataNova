---
const formStrings = {
  legend: 'Subscribe to our newsletter',
  placeholder: 'Enter your email',
  submit: 'Submit',
};
---

<form
  id="footer-expanded-newsletter-form"
  class="w-full md:w-1/2 xl:w-1/3"
  data-form="newsletter"
  novalidate
>
  <fieldset
    class="flex flex-col items-center gap-2 rounded-lg bg-teal-400 p-2 sm:flex-row sm:gap-3"
    aria-labelledby="footer-expanded-form-legend"
  >
    <legend
      id="footer-expanded-form-legend"
      class="sr-only text-lg font-medium text-slate-700"
      >{formStrings.legend}</legend
    >

    <div class="hidden" aria-hidden="true">
      <label for="footer-expanded-website">Website</label>
      <input
        type="text"
        id="footer-expanded-website"
        name="website"
        tabindex="-1"
        autocomplete="off"
      />
    </div>

    <div class="w-full">
      <label for="footer-expanded-email-input" class="sr-only"
        >{formStrings.placeholder}</label
      >
      <input
        type="email"
        id="footer-expanded-email-input"
        name="email"
        class="block w-full rounded-lg border-transparent px-4 py-3 text-sm focus:border-teal-700/80 focus:ring-teal-700/80 focus-visible:ring-2 focus-visible:ring-teal-700/80"
        placeholder={formStrings.placeholder}
        required
        aria-required="true"
        aria-label={formStrings.placeholder}
        aria-describedby="footer-expanded-form-status"
        autocomplete="email"
        spellcheck="false"
      />
    </div>

    <button
      type="submit"
      data-form-submit
      class="inline-flex w-full items-center justify-center gap-x-2 rounded-lg border border-transparent bg-teal-100 p-3 text-sm font-medium whitespace-nowrap text-slate-700 transition duration-300 hover:bg-teal-700/80 hover:text-white focus:bg-teal-700 focus:text-white focus:outline-hidden focus-visible:ring-2 focus-visible:ring-teal-700/80 focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto"
      aria-label="Submit email"
    >
      {formStrings.submit}
    </button>
  </fieldset>
  <p
    id="footer-expanded-form-status"
    class="mt-2 hidden text-sm"
    role="status"
    aria-live="polite"
    data-form-status
  >
  </p>
</form>

<script>
  import { bindJsonForm } from '@/utils/form-client';

  document.addEventListener('astro:page-load', () => {
    bindJsonForm({
      formId: 'footer-expanded-newsletter-form',
      endpoint: '/api/newsletter',
      submittingLabel: 'Sending…',
      defaultSubmitLabel: 'Submit',
    });
  });
</script>
