---
const formStrings = {
  legend: 'Subscribe to our newsletter',
  placeholder: 'Enter your email',
  submit: 'Submit',
  description:
    "Get all the information you need. Enter your email, and we'll be in touch.",
};
---

<form id="footer-newsletter-form" data-form="newsletter" novalidate>
  <fieldset
    class="mt-4 flex flex-col items-center gap-2 rounded-lg bg-teal-400 p-2 sm:flex-row sm:gap-3"
    aria-labelledby="footer-form-legend"
  >
    <legend
      id="footer-form-legend"
      class="sr-only text-lg font-medium text-slate-700"
      >{formStrings.legend}</legend
    >

    <div class="hidden" aria-hidden="true">
      <label for="footer-website">Website</label>
      <input
        type="text"
        id="footer-website"
        name="website"
        tabindex="-1"
        autocomplete="off"
      />
    </div>

    <div class="w-full">
      <label for="footer-email-input" class="sr-only"
        >{formStrings.placeholder}</label
      >
      <input
        type="email"
        id="footer-email-input"
        name="email"
        class="block w-full rounded-lg border-transparent px-4 py-3 text-sm focus:border-teal-700/80 focus:ring-teal-700/80 focus-visible:ring-2 focus-visible:ring-teal-700/80"
        placeholder={formStrings.placeholder}
        required
        aria-required="true"
        aria-label={formStrings.placeholder}
        aria-describedby="footer-form-description footer-form-status"
        autocomplete="email"
        spellcheck="false"
      />
    </div>

    <button
      type="submit"
      data-form-submit
      class="inline-flex w-full items-center justify-center gap-x-2 rounded-lg border border-transparent bg-teal-100 p-3 text-sm font-medium whitespace-nowrap text-slate-700 transition duration-300 hover:bg-teal-700/80 hover:text-white focus:bg-teal-700 focus:text-white focus:outline-hidden focus-visible:ring-2 focus-visible:ring-teal-700/80 focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto"
      aria-label="Submit email"
    >
      {formStrings.submit}
    </button>
  </fieldset>

  <p id="footer-form-description" class="mt-3 text-sm text-slate-400">
    {formStrings.description}
  </p>
  <p
    id="footer-form-status"
    class="mt-2 hidden text-sm"
    role="status"
    aria-live="polite"
    data-form-status
  >
  </p>
</form>

<script>
  import { bindFormspreeForm } from '@/utils/form-client';

  document.addEventListener('astro:page-load', () => {
    bindFormspreeForm({
      formId: 'footer-newsletter-form',
      endpointEnv: import.meta.env.PUBLIC_FORMSPREE_NEWSLETTER,
      submittingLabel: 'Sending…',
      defaultSubmitLabel: 'Submit',
      demoMessage:
        'Subscribed! (Demo mode – set PUBLIC_FORMSPREE_NEWSLETTER to deliver.)',
    });
  });
</script>
