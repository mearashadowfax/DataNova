---
const formStrings = {
  name: 'Name',
  email: 'Email',
  company: 'Company',
  message: 'Message',
  submit: 'Submit',
  licenseTypeLabel: 'License Type',
  licenseTypes: [
    'Essential Edition',
    'Advanced Edition',
    'Subscription License',
    'Other / Unsure',
  ],
};

/**
 * Quote request form – posts to /api/contact with optional company / licenseType.
 */
---

<form id="quote-form" class="p-4" data-form="quote" novalidate>
  <fieldset class="space-y-4">
    <legend class="sr-only">Request a quote</legend>

    <div class="hidden" aria-hidden="true">
      <label for="quote-website">Website</label>
      <input
        type="text"
        id="quote-website"
        name="website"
        tabindex="-1"
        autocomplete="off"
      />
    </div>

    <div class="relative">
      <input
        type="text"
        id="quote-name"
        name="name"
        class="peer block w-full rounded-lg border border-transparent p-4 text-sm not-placeholder-shown:pt-6 not-placeholder-shown:pb-2 placeholder:text-transparent autofill:pt-6 autofill:pb-2 focus:border-teal-700/80 focus:pt-6 focus:pb-2 focus:ring-2 focus:ring-teal-700/80 focus:outline-hidden focus-visible:ring-2 focus-visible:ring-teal-700/80"
        placeholder={formStrings.name}
        required
        aria-required="true"
        aria-labelledby="quote-name-label"
        autocomplete="name"
      />
      <label
        id="quote-name-label"
        for="quote-name"
        class="pointer-events-none absolute start-0 top-0 h-full truncate border border-transparent p-4 text-slate-600 transition duration-100 ease-in-out peer-not-placeholder-shown:-translate-y-1.5 peer-not-placeholder-shown:text-xs peer-not-placeholder-shown:text-slate-600 peer-focus:-translate-y-1.5 peer-focus:text-xs peer-focus:text-slate-600"
        >{formStrings.name}</label
      >
    </div>

    <div class="relative">
      <input
        type="text"
        id="quote-company"
        name="company"
        class="peer block w-full rounded-lg border border-transparent p-4 text-sm not-placeholder-shown:pt-6 not-placeholder-shown:pb-2 placeholder:text-transparent autofill:pt-6 autofill:pb-2 focus:border-teal-700/80 focus:pt-6 focus:pb-2 focus:ring-2 focus:ring-teal-700/80 focus:outline-hidden focus-visible:ring-2 focus-visible:ring-teal-700/80"
        placeholder={formStrings.company}
        required
        aria-required="true"
        aria-labelledby="quote-company-label"
        autocomplete="organization"
      />
      <label
        id="quote-company-label"
        for="quote-company"
        class="pointer-events-none absolute start-0 top-0 h-full truncate border border-transparent p-4 text-slate-600 transition duration-100 ease-in-out peer-not-placeholder-shown:-translate-y-1.5 peer-not-placeholder-shown:text-xs peer-not-placeholder-shown:text-slate-600 peer-focus:-translate-y-1.5 peer-focus:text-xs peer-focus:text-slate-600"
        >{formStrings.company}</label
      >
    </div>

    <div class="relative">
      <input
        type="email"
        id="quote-email"
        name="email"
        class="peer block w-full rounded-lg border border-transparent p-4 text-sm not-placeholder-shown:pt-6 not-placeholder-shown:pb-2 placeholder:text-transparent autofill:pt-6 autofill:pb-2 focus:border-teal-700/80 focus:pt-6 focus:pb-2 focus:ring-2 focus:ring-teal-700/80 focus:outline-hidden focus-visible:ring-2 focus-visible:ring-teal-700/80"
        placeholder={formStrings.email}
        required
        aria-required="true"
        aria-labelledby="quote-email-label"
        autocomplete="email"
      />
      <label
        id="quote-email-label"
        for="quote-email"
        class="pointer-events-none absolute start-0 top-0 h-full truncate border border-transparent p-4 text-slate-600 transition duration-100 ease-in-out peer-not-placeholder-shown:-translate-y-1.5 peer-not-placeholder-shown:text-xs peer-not-placeholder-shown:text-slate-600 peer-focus:-translate-y-1.5 peer-focus:text-xs peer-focus:text-slate-600"
        >{formStrings.email}</label
      >
    </div>

    <div class="relative">
      <select
        id="quote-license-type"
        name="licenseType"
        class="peer block w-full rounded-lg border border-transparent p-4 pe-9 text-sm not-placeholder-shown:pt-6 not-placeholder-shown:pb-2 autofill:pt-6 autofill:pb-2 focus:border-teal-700/80 focus:pt-6 focus:pb-2 focus:ring-2 focus:ring-teal-700/80 focus-visible:ring-2 focus-visible:ring-teal-700/80"
        required
        aria-required="true"
        aria-labelledby="quote-license-type-label"
      >
        {
          formStrings.licenseTypes.map(type => (
            <option value={type}>{type}</option>
          ))
        }
      </select>
      <label
        for="quote-license-type"
        id="quote-license-type-label"
        class="pointer-events-none absolute start-0 top-0 h-full truncate border border-transparent p-4 transition duration-100 ease-in-out peer-not-placeholder-shown:-translate-y-1.5 peer-not-placeholder-shown:text-xs peer-not-placeholder-shown:text-slate-500 peer-focus:-translate-y-1.5 peer-focus:text-xs peer-focus:text-slate-500"
        >{formStrings.licenseTypeLabel}</label
      >
    </div>

    <div class="relative">
      <textarea
        id="quote-message"
        name="message"
        class="peer block w-full rounded-lg border border-transparent p-4 text-sm not-placeholder-shown:pt-6 not-placeholder-shown:pb-2 placeholder:text-transparent autofill:pt-6 autofill:pb-2 focus:border-teal-700/80 focus:pt-6 focus:pb-2 focus:ring-2 focus:ring-teal-700/80 focus:outline-hidden focus-visible:ring-2 focus-visible:ring-teal-700/80"
        placeholder={formStrings.message}
        required
        aria-required="true"
        aria-labelledby="quote-message-label"></textarea>
      <label
        id="quote-message-label"
        for="quote-message"
        class="pointer-events-none absolute start-0 top-0 h-full truncate border border-transparent p-4 text-slate-600 transition duration-100 ease-in-out peer-not-placeholder-shown:-translate-y-1.5 peer-not-placeholder-shown:text-xs peer-not-placeholder-shown:text-slate-600 peer-focus:-translate-y-1.5 peer-focus:text-xs peer-focus:text-slate-600"
        >{formStrings.message}</label
      >
    </div>
  </fieldset>

  <p
    id="quote-form-status"
    class="mt-4 hidden text-sm"
    role="status"
    aria-live="polite"
    data-form-status
  >
  </p>

  <div class="mt-8">
    <button
      type="submit"
      data-form-submit
      class="inline-flex items-center rounded-lg bg-teal-100 px-6 py-2 font-medium text-nowrap text-slate-700 transition-colors duration-300 hover:bg-teal-700/80 hover:text-white focus:bg-teal-700/80 focus:outline-hidden focus-visible:ring-2 focus-visible:ring-teal-700/80 focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-60"
    >
      {formStrings.submit}
    </button>
  </div>
</form>

<script>
  import { bindJsonForm } from '@/utils/form-client';

  document.addEventListener('astro:page-load', () => {
    bindJsonForm({
      formId: 'quote-form',
      endpoint: '/api/contact',
      submittingLabel: 'Sending…',
      defaultSubmitLabel: 'Submit',
    });
  });
</script>
